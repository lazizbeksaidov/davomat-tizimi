{
  "rules": {
    "attendance": {
      ".read": "auth != null",
      "$dateKey": {
        "$empKey": {
          ".write": "auth != null && (root.child('user_roles').child(auth.uid).val() === 'admin' || root.child('user_roles').child(auth.uid).val() === 'boss')",
          ".validate": "newData.hasChild('status')",
          "status": {
            ".validate": "newData.isString() && newData.val().matches(/^(present|late|absent|sick|trip|training|vacation|excused|holiday)$/)"
          },
          "morning": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 480" },
          "afternoon": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 480" },
          "note": { ".validate": "newData.isString() && newData.val().length <= 500" }
        }
      }
    },
    "checkins": {
      ".read": "auth != null",
      "$dateKey": {
        "$empKey": {
          "morning": {
            ".write": "auth != null && (root.child('user_roles').child(auth.uid).val() === 'admin' || root.child('user_roles').child(auth.uid).val() === 'boss' || root.child('users').child(auth.uid).child('empKey').val() === $empKey)",
            ".validate": "newData.hasChild('time')",
            "time": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "photo": { ".validate": "newData.isString() && newData.val().length <= 800000" },
            "gpsLat": { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
            "gpsLng": { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
            "gpsDistance": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
            "gpsOk": { ".validate": "newData.isBoolean()" },
            "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "lateMinutes": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 480" },
            "empNote": { ".validate": "newData.isString() && newData.val().length <= 1000" },
            "session": { ".validate": "newData.isString()" },
            "arrivedBeforeDeadline": { ".validate": "newData.isBoolean()" },
            "deadline": { ".validate": "newData.isString() && newData.val().length <= 20" }
          },
          "afternoon": {
            ".write": "auth != null && (root.child('user_roles').child(auth.uid).val() === 'admin' || root.child('user_roles').child(auth.uid).val() === 'boss' || root.child('users').child(auth.uid).child('empKey').val() === $empKey)",
            ".validate": "newData.hasChild('time')",
            "time": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "photo": { ".validate": "newData.isString() && newData.val().length <= 800000" },
            "gpsLat": { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
            "gpsLng": { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
            "gpsDistance": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
            "gpsOk": { ".validate": "newData.isBoolean()" },
            "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "lateMinutes": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 480" },
            "empNote": { ".validate": "newData.isString() && newData.val().length <= 1000" },
            "session": { ".validate": "newData.isString()" },
            "arrivedBeforeDeadline": { ".validate": "newData.isBoolean()" },
            "deadline": { ".validate": "newData.isString() && newData.val().length <= 20" }
          }
        }
      }
    },
    "employees": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('user_roles').child(auth.uid).val() === 'admin'",
      "$empKey": {
        ".validate": "newData.hasChild('firstName') && newData.hasChild('lastName')"
      }
    },
    "holidays": {
      ".read": "auth != null",
      "$holId": {
        ".write": "auth != null && (root.child('user_roles').child(auth.uid).val() === 'admin' || root.child('user_roles').child(auth.uid).val() === 'boss')",
        ".validate": "newData.hasChild('name') && newData.hasChild('date')"
      }
    },
    "employee_notes": {
      ".read": "auth != null",
      "$noteId": {
        ".write": "auth != null",
        ".validate": "newData.hasChild('empName') && newData.hasChild('text') && newData.hasChild('timestamp')"
      }
    },
    "announcements": {
      ".read": "auth != null",
      "$annId": {
        ".write": "auth != null && root.child('user_roles').child(auth.uid).val() === 'admin'",
        ".validate": "newData.hasChild('title') && newData.hasChild('text') && newData.hasChild('timestamp')"
      }
    },
    "telegram_config": {
      ".read": "auth != null && root.child('user_roles').child(auth.uid).val() === 'admin'",
      ".write": "auth != null && root.child('user_roles').child(auth.uid).val() === 'admin'"
    },
    "ijro": {
      ".read": "auth != null",
      "$dateKey": {
        "$empKey": {
          ".write": "auth != null && (root.child('user_roles').child(auth.uid).val() === 'admin' || root.child('user_roles').child(auth.uid).val() === 'boss')",
          ".validate": "newData.hasChild('total') && newData.hasChild('overdue')"
        }
      }
    },
    "office_location": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('user_roles').child(auth.uid).val() === 'admin'",
      ".validate": "newData.hasChild('lat') && newData.hasChild('lng') && newData.hasChild('radius')"
    },
    "whitelist": {
      ".read": "auth != null && (root.child('user_roles').child(auth.uid).val() === 'admin' || root.child('user_roles').child(auth.uid).val() === 'boss')",
      ".write": "auth != null && root.child('user_roles').child(auth.uid).val() === 'admin'",
      "$wlId": {
        ".validate": "newData.hasChild('phone') && newData.hasChild('name')",
        "phone": { ".validate": "newData.isString() && newData.val().length >= 9 && newData.val().length <= 20" },
        "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "role": { ".validate": "newData.isString() && newData.val().matches(/^(admin|boss|observer|employee)$/)" },
        "title": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "linkEmail": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "active": { ".validate": "newData.isBoolean()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "createdBy": { ".validate": "newData.isString() && newData.val().length <= 100" }
      }
    },
    "tg_sessions": {
      ".read": false,
      ".write": false
    },
    "tg_logins": {
      ".read": false,
      ".write": false
    },
    "vacation_requests": {
      ".read": "auth != null",
      ".indexOn": ["status", "empKey", "timestamp"],
      "$reqId": {
        ".write": "auth != null",
        ".validate": "newData.hasChild('empKey') && newData.hasChild('start') && newData.hasChild('end') && newData.hasChild('status')"
      }
    },
    "audit_log": {
      ".read": "auth != null && root.child('user_roles').child(auth.uid).val() === 'admin'",
      "$logId": {
        ".write": "auth != null && !data.exists()",
        ".validate": "newData.hasChild('action') && newData.hasChild('timestamp')",
        "action": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now + 60000 && newData.val() >= now - 86400000" },
        "detail": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "$other": { ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()" }
      }
    },
    "config": {
      ".read": false,
      ".write": false
    },
    "user_roles": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('user_roles').child(auth.uid).val() === 'admin'"
      }
    },
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('user_roles').child(auth.uid).val() === 'admin')",
        "name": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "firstName": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "lastName": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "fullName": { ".validate": "newData.isString() && newData.val().length <= 300" },
        "phone": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "position": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "department": { ".validate": "newData.isString() && newData.val().length <= 300" },
        "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "birthDate": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "birthPlace": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "education": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "specialty": { ".validate": "newData.isString() && newData.val().length <= 300" },
        "languages": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "photo": { ".validate": "newData.isString() && newData.val().length <= 800000" },
        "schedule": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "role": { ".validate": "newData.isString() && newData.val().matches(/^(admin|boss|observer|employee)$/)" },
        "createdAt": { ".validate": "newData.isNumber()" }
      }
    },
    "$other": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
